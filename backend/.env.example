# ══════════════════════════════════════════════════════
#  FinWise AI — .env.example (Template for deployment)
# ══════════════════════════════════════════════════════

PORT=3000
NODE_ENV=production

# ── MongoDB Atlas ──────────────────────────────────────
# Get from: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/finwise?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=30d

# ── AI Providers (Multi-Provider with Fallback) ────────
# Add at least ONE key below to enable AI features

# OpenAI (Recommended)
# Get key → https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (Free tier: 60 requests/min)
# Get key → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-pro

# Anthropic Claude (Fallback)
# Get key → https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
AI_MODEL=claude-sonnet-4-6

# Hugging Face (FREE - 1000 requests/day)
# Get token → https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your-huggingface-token-here

# ── AI Configuration ───────────────────────────────────
AI_MAX_TOKENS=1024
AI_CONTEXT_MESSAGES=12

# ── Email Configuration ────────────────────────────────
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password